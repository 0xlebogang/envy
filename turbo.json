{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "build/**"
      ]
    },
    "test": {},
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {}
  }
}
