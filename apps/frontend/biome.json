{
	"$schema": "../../node_modules/@biomejs/biome/configuration_schema.json",
	"root": false,
	"extends": "//",
	"linter": {
		"enabled": true,
		"rules": {
			"suspicious": {
				"noUnknownAtRules": "off"
			}
		},
		"domains": {
			"next": "recommended",
			"react": "recommended"
		}
	},
	"css": {
		"parser": {
			"allowWrongLineComments": true,
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["src/components/ui/*", "src/lib/utils.ts"],
			"linter": {
				"enabled": false
			},
			"formatter": {
				"enabled": true
			}
		}
	]
}
